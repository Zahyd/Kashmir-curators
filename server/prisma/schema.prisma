generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String
  emailVerified     Boolean            @default(false)
  image             String?
  password          String?
  phone             String?
  role              String             @default("user") // user, admin, sales, operations, finance, agent, supplier, driver
  employeeCode      String?            @unique
  isOnline          Boolean            @default(false)
  leadCapacity      Int                @default(5)
  bookings          Booking[]
  inquiries         Inquiry[]
  agentInquiries    Inquiry[]          @relation("AgentInquiries")
  hotelReservations HotelReservation[] @relation("UserReservations")
  uploadedDocuments String?            // JSON string of uploaded documents
  agentProfile      AgentProfile?
  driverProfile     DriverProfile?
  supplierProfile   Supplier?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  sessions      Session[]
  accounts      Account[]
}

model Package {
  id            String   @id @default(uuid())
  name          String
  destination   String
  duration      String
  price         Float
  originalPrice Float
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  image         String
  highlights    String   // JSON string or comma-separated
  inclusions    String   // JSON string or comma-separated
  exclusions    String   // JSON string or comma-separated
  itinerary     String   // JSON string
  bestSeason    String
  difficulty    String
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Hotel {
  id                  String             @id @default(uuid())
  name                String
  location            String
  starRating          Int
  rating              Float              @default(0)
  reviewCount         Int                @default(0)
  pricePerNight       Float
  image               String
  description         String
  amenities           String             // JSON string
  roomTypes           String             // JSON string
  isActive            Boolean            @default(true)
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  paymentTerms        String?
  commissionStructure String?
  seasonalPricing     String?            // JSON string
  reservations        HotelReservation[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Cab {
  id         String   @id @default(uuid())
  type       String
  name       String
  capacity   Int
  pricePerKm Float
  basePrice  Float
  image      String
  features   String   // JSON string
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  avatar      String
  location    String
  rating      Int
  content     String
  packageName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String   @default("general")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Booking {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String   // hotel, package, cab
  itemName     String
  bookingDate  DateTime
  status       String   @default("pending") // pending, confirmed, cancelled
  stage        String   @default("DRAFT") // DRAFT, SUPPLIER_REQUESTED, CONFIRMED, VOUCHERED, EXECUTED, COMPLETED, CANCELLED
  totalAmount  Float
  details      String   // JSON string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id                String             @id @default(uuid())
  userId            String?
  user              User?              @relation(fields: [userId], references: [id])
  customerName      String
  email             String
  phone             String
  destination       String
  duration          String
  travelers         String
  budget            String
  accommodation     String
  status            String             @default("New") // New, Pending Curation, Ready for Review, Booked, Lost
  leadStage         String             @default("NEW_LEAD") // NEW_LEAD, FOLLOW_UP, QUOTE_SENT, NEGOTIATION, PAYMENT_PENDING, CONFIRMED, COMPLETED, CANCELLED
  assignedTo        String?            // Sales team user code
  priority          String?            // Low, Medium, High
  sentiment         String?            // Cold, Warm, Hot, Ready to Book
  quoteData         String?            // JSON string of days/pricing
  proposalUrl       String?            // URL to uploaded PDF
  flightDetails     String?            // JSON string of flight preferences / enquiry details
  feedback          String?            // Client comments / modification requests
  netPrice          Float              @default(0.0)
  agentMarkup       Float              @default(0.0)
  agentId           String?
  agent             User?              @relation("AgentInquiries", fields: [agentId], references: [id])
  hotelReservations HotelReservation[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Media {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  url          String
  size         Int?
  mimeType     String?
  publicId     String?  // Cloudinary public_id
  createdAt    DateTime @default(now())
}

model TransactionLedger {
  id           String   @id @default(uuid())
  bookingId    String
  amount       Float
  type         String   // CREDIT, DEBIT
  paymentId    String   @unique
  orderId      String
  description  String?
  createdAt    DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  author      String
  imageUrl    String?
  seoKeywords String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeasonalCampaign {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  season      String   // Winter, Spring, Summer, Autumn
  description String
  bannerImage String?
  isActive    Boolean  @default(false)
  startDate   DateTime?
  endDate     DateTime?
  packages    String   // JSON array of associated package IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SiteContent {
  id         String   @id @default(uuid())
  sectionKey String   @unique
  title      String?
  subtitle   String?
  content    Json
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Curator {
  id           String    @id @default(uuid())
  name         String
  role         String
  licenseNo    String
  avatar       String
  bio          String
  languages    String
  phone        String
  rating       Float     @default(5.0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TravelAdvisory {
  id           String    @id @default(uuid())
  location     String
  status       String
  message      String
  lastUpdated  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PackageReview {
  id           String    @id @default(uuid())
  packageId    String
  userId       String?
  userName     String
  userAvatar   String?
  rating       Int
  text         String
  date         DateTime  @default(now())
  helpful      Int       @default(0)
  tripType     String?
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model HotelReservation {
  id               String    @id @default(uuid())
  inquiryId        String?
  inquiry          Inquiry?  @relation(fields: [inquiryId], references: [id])
  hotelId          String
  hotel            Hotel     @relation(fields: [hotelId], references: [id])
  guestName        String
  guestEmail       String?
  guestPhone       String?
  checkIn          DateTime
  checkOut         DateTime
  roomType         String
  roomsCount       Int       @default(1)
  mealPlan         String    // EP, CP, MAP, AP
  specialRequests  String?
  status           String    @default("Pending") // Pending, Sent, Confirmed, Hold, Rejected, Cancelled
  paymentStatus    String    @default("Unpaid")  // Unpaid, Partially Paid, Paid
  bookingReference String?
  contractRate     Float     @default(0)
  seasonalPricing  Float?
  commissionRate   Float     @default(0)
  totalAmount      Float     @default(0)
  profitMargin     Float     @default(0)
  hotelDues        Float     @default(0)
  holdUntil        DateTime? // hold countdown timer
  createdById      String?
  createdBy        User?     @relation("UserReservations", fields: [createdById], references: [id])
  auditLogs        String?   // JSON string of updates/actions
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AgentProfile {
  id             String   @id @default(uuid())
  companyName    String
  licenseNumber  String?
  agentCode      String   @unique
  commissionPct  Float    @default(0.0)
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverProfile {
  id             String   @id @default(uuid())
  licenseNumber  String
  vehicleRegNo   String
  status         String   @default("AVAILABLE") // AVAILABLE, BUSY, OFFLINE
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id             String   @id @default(uuid())
  companyName    String
  contactPerson  String
  email          String
  phone          String
  type           String   // HOTEL, TRANSPORT, GUIDE
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String   // JSON string of changes
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  // Target user code or ID, null for global/admin
  title     String
  message   String
  type      String   // info, success, warning, booking, inquiry, payment
  read      Boolean  @default(false)
  priority  String   @default("medium") // low, medium, high
  link      String?  // Redirect link (e.g. /admin)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
